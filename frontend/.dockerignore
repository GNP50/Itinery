# ==============================================================================
# frontend/.dockerignore – Reduce frontend build context
# ==============================================================================

# Dependencies (will be installed during build)
node_modules/
.pnp
.pnp.js

# Testing
coverage/
.nyc_output/

# Build outputs (will be generated)
dist/
build/
.next/
out/

# Development files
.env.local
.env.development.local
.env.test.local
.env.production.local

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Git
.git/
.gitignore

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Documentation
*.md
README*
CHANGELOG*
LICENSE*

# OS
Thumbs.db
Desktop.ini

# Temporary files
.tmp/
tmp/
temp/

# Storybook
storybook-static/
